<?xml version="1.0" encoding="utf-8"?>
<!--
    PerfEngine Event ID Definitions (Single Source of Truth)

    Auto-generates:
      - Java constants for Framework overlay  (id/name only)
      - Java constants for SDK               (id/name only)
      - C++ constants for Native layer       (id/name only)
      - Markdown documentation               (id/name/desc/hook/priority/params)

    priority: integer 1-10, higher = more important.
      1-3  : low    — wallpaper render, widget ops
      4-6  : normal — scroll, fling, animation
      7-8  : high   — app launch, activity switch, camera
      9-10 : critical — input, boot

    Param/@index : 0-based position in intParams[] or extraStrings (split by \x1F)
    Param/@type  : int | String
    Param/@required : true | false

    NOTE: priority and Params are doc/runtime-only.
          Code generators (.h/.java) ignore them entirely.
-->
<PerfEngineEvents version="3.0">

    <!-- ========== Range Definitions ========== -->
    <Ranges>
        <Range name="RANGE_SYS"              start="0x00000" end="0x00FFF"
               description="System-level events (Framework internal hooks)"/>
        <Range name="RANGE_APP_SYSTEMUI"     start="0x01000" end="0x01FFF"
               description="SystemUI application events"/>
        <Range name="RANGE_APP_LAUNCHER"     start="0x02000" end="0x02FFF"
               description="Launcher application events"/>
        <Range name="RANGE_APP_WALLPAPER"    start="0x03000" end="0x03FFF"
               description="Wallpaper application events"/>
        <Range name="RANGE_APP_SETTINGS"     start="0x04000" end="0x04FFF"
               description="Settings application events"/>
        <Range name="RANGE_APP_RESERVED"     start="0x05000" end="0x0FFFF"
               description="Reserved for future system apps"/>
        <Range name="RANGE_APP_THIRDPARTY"   start="0x10000" end="0xEFFFF"
               description="Third-party application events"/>
        <Range name="RANGE_INTERNAL"         start="0xF0000" end="0xFFFFF"
               description="Internal test/debug events"/>
    </Ranges>

