package {
    default_applicable_licenses: ["vendor_transsion_license"],
}

// ==================== Transsion Framework Overlay ====================

filegroup {
    name: "transsion_framework_overlay_sources",
    srcs: [
        "frameworks/base/core/java/android/util/*.java",
        ":perfengine-event-constants-java-overlay",
    ],
    visibility: ["//frameworks/base"],
}

android_app {
    name: "PerfEnginePermissionOverlay",
    sdk_version: "current",
    certificate: "platform",
    privileged: false,
    system_ext_specific: false,
    manifest: "frameworks/base/core/res/AndroidManifest.xml",
}

prebuilt_etc {
    name: "privapp-permissions-perfengine",
    src: "etc/permissions/privapp-permissions-perfengine.xml",
    sub_dir: "permissions",
    system_ext_specific: false,
    filename: "privapp-permissions-perfengine.xml",
}
