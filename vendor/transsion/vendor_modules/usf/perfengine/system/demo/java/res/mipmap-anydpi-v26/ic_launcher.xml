<?xml version="1.0" encoding="utf-8"?>
<!--
    ic_launcher.xml  (mipmap-anydpi-v26)
    AdaptiveIcon requires API 26+. Since this app ships with the ROM
    (no API-level concern), this is the only launcher icon definition needed.
    The system applies its own mask shape (circle / squircle / rounded-rect
    depending on launcher), clipping both layers consistently.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@drawable/ic_launcher_background"/>
    <foreground android:drawable="@drawable/ic_launcher_foreground"/>
</adaptive-icon>  
