license {
    name: "vendor_transsion_license",
    visibility: ["//visibility:public"],
    license_kinds: [
        "SPDX-license-identifier-Apache-2.0",
    ],
    license_text: [
        "LICENSE",
    ],
}

// ==================== Event Constants Generation ====================

python_binary_host {
    name: "perfengine-event-generator",
    main: "tools/generate_events.py",
    srcs: ["tools/generate_events.py"],
    version: {
        py3: {
            enabled: true,
        },
    },
}

genrule {
    name: "perfengine-event-constants-cpp",
    srcs: ["event_definitions.xml"],
    out: [
        "TranPerfEventConstants.h",
        "TranPerfEventImportMacro.h",
    ],
    tools: ["perfengine-event-generator"],
    cmd: "$(location perfengine-event-generator) $(in) --out-cpp-dir $(genDir)",
}

genrule {
    name: "perfengine-event-constants-java-overlay",
    srcs: ["event_definitions.xml"],
    out: ["TranPerfEventConstants.java"],
    tools: ["perfengine-event-generator"],
    cmd: "$(location perfengine-event-generator) $(in) --out-java $(out)",
}

// ==================== System 分区模块聚合 ====================

phony {
    name: "perfengine_system",
    required: [
        // Framework 实现层
        "perfengine_impl",
        "PerfEngineDemo",
        "perfengine_demo",
        // System Native Client
        "libperfengine-client",

        // AIDL 接口
        "vendor.transsion.hardware.perfengine-V1-ndk",
        "vendor.transsion.hardware.perfengine-V1-java",
        // Aconfig Flags
        //"com.transsion.perfengine.flags-aconfig-java",
        //"libperfengine_flags_c",
        //"libaconfig_storage_read_api_cc",
    ],
}

// ==================== Vendor 分区模块聚合 ====================

phony {
    name: "perfengine_vendor",
    required: [
        // Vendor Service
        "libperfengine-adapter",
        "libperfengine-client",
        // AIDL 接口
        "vendor.transsion.hardware.perfengine-V1-ndk",

        // Aconfig Flags
        // "libperfengine_flags_c",
    ],
}
