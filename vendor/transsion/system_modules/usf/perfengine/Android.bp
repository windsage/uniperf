        "perfengine_demo",
        // System Native Client
        "libperfengine-client",
        // AIDL 接口
        "vendor.transsion.hardware.perfengine-V1-ndk",
        "vendor.transsion.hardware.perfengine-V1-java",
        //"libperfengine_flags_c",
        //"libaconfig_storage_read_api_cc",
    ],
}
