<?xml version="1.0" encoding="utf-8"?>
<!--
    ic_launcher_background.xml
    Adaptive icon background layer — solid deep navy #0D1B2A.
    108dp x 108dp per AdaptiveIcon spec.
    Kept as a plain solid color; no inner artwork needed since the
    foreground layer carries all visual detail.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <path
        android:pathData="M0,0 H108 V108 H0 Z"
        android:fillColor="#0D1B2A"/>

    <!--
        Subtle inner-ring accent at top-left — visible at large sizes,
        disappears naturally at small sizes due to antialiasing.
        Keeps the background from feeling completely flat.
    -->
    <path
        android:pathData="M0,0 Q40,0 40,40 Q40,0 80,0"
        android:fillColor="#00000000"
        android:strokeColor="#1E3A5F"
        android:strokeWidth="0.8"/>

</vector>
